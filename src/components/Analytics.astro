---
/**
 * PostHog web analytics (EU cloud, cookieless).
 *
 * Two guards ensure ONLY the live site sends events:
 *   1. `import.meta.env.PROD` — keeps this code out of the dev bundle entirely,
 *      so `npm run dev` never loads PostHog.
 *   2. Runtime hostname check — additionally prevents local production builds
 *      (`npm run build && npm run preview`) from sending to the live instance.
 *      Only renestrammer.com is tracked.
 *
 * The PostHog project key is public-by-design (see CLAUDE.md) and may live in
 * the shipped client bundle.
 *
 * Note: this site uses Astro `<ClientRouter />` (View Transitions). Page changes
 * are therefore client-side and do NOT trigger a full reload. That is why
 * `capture_pageview: false` is set and pageviews are captured manually on the
 * `astro:page-load` event (fires on first load AND on every View Transition
 * navigation) — exactly one pageview per page, no double counting.
 */
---

{
  import.meta.env.PROD && (
    <script is:inline>
      (function () {
        var LIVE_HOST = "renestrammer.com";
        var host = window.location.hostname;
        if (host !== LIVE_HOST && host !== "www." + LIVE_HOST) return;

        // Init guard: under View Transitions PostHog must start only once.
        if (window.__phInit) return;
        window.__phInit = true;

        // Official PostHog loader (stub; loads array.js asynchronously).
        !(function (t, e) {
          var o, n, p, r;
          e.__SV ||
            ((window.posthog = e),
            (e._i = []),
            (e.init = function (i, s, a) {
              function g(t, e) {
                var o = e.split(".");
                2 == o.length && ((t = t[o[0]]), (e = o[1])),
                  (t[e] = function () {
                    t.push([e].concat(Array.prototype.slice.call(arguments, 0)));
                  });
              }
              ((p = t.createElement("script")).type = "text/javascript"),
                (p.crossOrigin = "anonymous"),
                (p.async = !0),
                (p.src =
                  s.api_host.replace(".i.posthog.com", "-assets.i.posthog.com") +
                  "/static/array.js"),
                (r = t.getElementsByTagName("script")[0]).parentNode.insertBefore(
                  p,
                  r
                );
              var u = e;
              for (
                void 0 !== a ? (u = e[a] = []) : (a = "posthog"),
                  u.people = u.people || [],
                  u.toString = function (t) {
                    var e = "posthog";
                    return (
                      "posthog" !== a && (e += "." + a), t || (e += " (stub)"), e
                    );
                  },
                  u.people.toString = function () {
                    return u.toString(1) + ".people (stub)";
                  },
                  o =
                    "init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty createPersonProfile opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug getPageViewId captureTraceFeedback captureTraceMetric".split(
                      " "
                    ),
                  n = 0;
                n < o.length;
                n++
              )
                g(u, o[n]);
              e._i.push([i, s, a]);
            }),
            (e.__SV = 1));
        })(document, window.posthog || []);

        posthog.init("phc_CP4GdXTMZydE4YpdphigNat9SK5B98RGkq7dKqvvZKvM", {
          api_host: "https://eu.i.posthog.com",
          defaults: "2026-05-30",
          person_profiles: "identified_only",
          persistence: "memory", // cookieless: no cookie, no banner
          capture_pageview: false, // captured manually via astro:page-load (View Transitions)
        });

        // Capture exactly once on first load AND on every View Transition navigation.
        document.addEventListener("astro:page-load", function () {
          if (window.posthog) window.posthog.capture("$pageview");
        });
      })();
    </script>
  )
}
