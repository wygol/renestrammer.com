---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const title = "Kontakt";
const description =
  "Kontaktmöglichkeiten zu René Strammer — per E-Mail und über weitere Kanäle.";
---

<Layout title={`${title} | ${config.site.title}`} description={description}>
  <Header />

  <Breadcrumb />

  <Main pageTitle={title}>
    <div class="border-border bg-muted mt-4 rounded-lg border p-6 sm:p-8">
      <p class="text-lg">
        Du möchtest dich vernetzen, hast eine Frage, ein spannendes
        Geodaten-Projekt oder einen passenden Job für mich? Dann freue ich mich
        über deine Nachricht!
      </p>

      <div class="mt-6 space-y-3">
        <p>
          <span class="font-semibold">E-Mail:</span>{" "}
          <a
            class="text-accent underline decoration-dashed underline-offset-4"
            href="mailto:rene.strammer@gmx.at"
          >
            rene.strammer@gmx.at
          </a>
        </p>
        <p>
          <span class="font-semibold">GitHub:</span> github.com/wygol
        </p>
        <p>
          <span class="font-semibold">LinkedIn:</span> linkedin.com/in/renestrammer
        </p>
      </div>

      <p class="text-muted-foreground mt-6 text-sm">
        Diese Seite hat bewusst kein Formular... schreib mir einfach direkt eine
        Nachricht.
      </p>
    </div>
  </Main>

  <Footer />
</Layout>
